class Solution {
    public String reverseVowels(String s) {
        char[] s1 = s.toCharArray();
        int i = 0;
        int j = s1.length - 1;

        while (i < j) {

            char temp;

            if (
                (s1[i] == 'a' || s1[i] == 'e' || s1[i] == 'i' || s1[i] == 'o' || s1[i] == 'u' ||
                 s1[i] == 'A' || s1[i] == 'E' || s1[i] == 'I' || s1[i] == 'O' || s1[i] == 'U')   
                &&
                (s1[j] == 'a' || s1[j] == 'e' || s1[j] == 'i' || s1[j] == 'o' || s1[j] == 'u' ||
                 s1[j] == 'A' || s1[j] == 'E' || s1[j] == 'I' || s1[j] == 'O' || s1[j] == 'U')   
            ) {

                temp = s1[i];
                s1[i] = s1[j];
                s1[j] = temp;
                i++;
                j--;

            }

            else if (
                (s1[i] == 'a' || s1[i] == 'e' || s1[i] == 'i' || s1[i] == 'o' || s1[i] == 'u' ||
                 s1[i] == 'A' || s1[i] == 'E' || s1[i] == 'I' || s1[i] == 'O' || s1[i] == 'U')  
                &&
                (s1[j] != 'a' && s1[j] != 'e' && s1[j] != 'i' && s1[j] != 'o' && s1[j] != 'u' &&
                 s1[j] != 'A' && s1[j] != 'E' && s1[j] != 'I' && s1[j] != 'O' && s1[j] != 'U')   
            ) {

                j--;

            }

            else if (
                (s1[i] != 'a' && s1[i] != 'e' && s1[i] != 'i' && s1[i] != 'o' && s1[i] != 'u' &&
                 s1[i] != 'A' && s1[i] != 'E' && s1[i] != 'I' && s1[i] != 'O' && s1[i] != 'U')   
                &&
                (s1[j] == 'a' || s1[j] == 'e' || s1[j] == 'i' || s1[j] == 'o' || s1[j] == 'u' ||
                 s1[j] == 'A' || s1[j] == 'E' || s1[j] == 'I' || s1[j] == 'O' || s1[j] == 'U')   
            ) {

                i++;

            }

            else {                     
                i++;                    
                j--;                    
            }
        }

        return new String(s1);          
